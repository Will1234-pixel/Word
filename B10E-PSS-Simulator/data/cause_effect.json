  "timing_constants": {
    "_about": "Verified from program.pdf Global Variables (HIMA SILworX). These are the real PLC presets.",
    "MAX_SEARCH_TIME": "180s  (overall search watchdog: START_SEARCH -> STANDBY must finish within 180s)",
    "STEP_MIN_TIME": "5s   (each T->T step must take at least 5s; faster = abort, anti-tailgating)",
    "STEP_MAX_TIME": "60s  (each T->T step must take at most 60s; slower = abort)",
    "BEAM_DELAY_TIMER_TIME": "180s (STANDBY -> BEAM_ON dwell: 'radiation imminent' warning period)",
    "RESET_DELAY_TIMER": "60s  (delay returning to OPEN)",
    "DOOR_UNLOCK_DELAY": "20s  (SIF-03: current+voltage must read ~zero for 20s before Open/Reset is allowed)",
    "LIGHT_CURTAIN_DELAY": "2s   (after Hutch_Entered, light-curtain monitoring arms after 2s)",
    "CONTACTOR_DELAY_200ms": "200ms (gate/RF contactor group CON06-10 trip delay)"
  },

