  "sifs": [
    {"id": "SIF-01", "title": "General Access Door open -> isolate Electron Source", "sil": 2,
     "causes": ["group:A", "group:B"], "logic": "If General Access Door (A) OR Gate (B) voted-open, de-energise electron-source contactors.",
     "effects_trip": ["CON01", "CON02", "CON03", "CON06", "CON07", "CON08"], "timing": "200ms (CON06/07/08), instant (CON01-03)"},
    {"id": "SIF-02", "title": "Service Access Door open -> isolate Electron Source", "sil": 2,
     "causes": ["group:C", "group:D"], "logic": "If Service Access Door (C or D) voted-open, de-energise electron-source contactors.",
     "effects_trip": ["CON01", "CON02", "CON03"], "timing": "instant"},
    {"id": "SIF-03", "title": "Radiation present interlock (keep doors locked) / OPEN permit", "sil": 2,
     "causes": ["group:E", "group:F"], "logic": "While CURRENT (E) or VOLTAGE (F) transmitters show source present, keep doors LOCKED. Only when both read ~0 (4mA) AND 12s delay AND Open/Reset pressed -> allow OPEN.",
     "effects_trip": ["GADL01", "GADL02", "GADL03", "GADL04", "SADL01", "SADL02"], "timing": "12s + open/reset"},
    {"id": "SIF-04", "title": "Area search (light curtain + ASB1-4)", "sil": 2,
     "causes": ["LCRx", "ASB01", "ASB02", "ASB03", "ASB04"], "logic": "Sequential search T2-T6; any out-of-order or light-curtain re-interrupt aborts the search.",
     "effects_trip": [], "timing": "sequence"},
    {"id": "SIF-05", "title": "Service-access area search", "sil": 2,
     "causes": ["group:C", "group:D", "ASB02", "ASB03", "ASB04"], "logic": "Search of service-access zone (T4-T6).",
     "effects_trip": [], "timing": "sequence"},
    {"id": "SIF-06", "title": "Search final / hutch secured", "sil": 2,
     "causes": ["SCR", "KEY02", "ASBF", "group:A", "group:B"], "logic": "T1 (card+key) ... T7 (final button) with all doors closed completes the search; arms the locks and beam permit.",
     "effects_trip": [], "timing": "180s search window, 180s beam-on delay"},
    {"id": "SIF-07", "title": "Door lock control", "sil": 2,
     "causes": ["search_complete"], "logic": "Energise door/gate lock solenoids (lock doors) once search complete & hazard armed.",
     "effects_energise": ["GADL01", "GADL02", "GADL03", "GADL04", "SADL01", "SADL02"], "timing": "180s delay (c)"},
    {"id": "SIF-08", "title": "Beam-Off Button -> trip", "sil": 2,
     "causes": ["group:J"], "logic": "Any 1 of 8 beam-off buttons removes electron-source AND RF contactors (defence in depth).",
     "effects_trip": ["CON01", "CON02", "CON03", "CON06", "CON07", "CON08", "CON09", "CON10"], "timing": "instant"},
    {"id": "SIF-09", "title": "Radiation Monitor -> trip", "sil": 2,
